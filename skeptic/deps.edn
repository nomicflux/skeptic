{:paths ["src"]
 :deps {prismatic/schema               {:mvn/version "1.4.1"}
        prismatic/plumbing             {:mvn/version "0.6.0"}
        metosin/malli                  {:mvn/version "0.20.1"}
        org.clojure/clojure            {:mvn/version "1.12.0"}
        org.clojure/clojurescript      {:mvn/version "1.11.132"}
        org.clojure/data.json          {:mvn/version "2.5.1"}
        org.clojure/tools.analyzer     {:mvn/version "1.2.2"}
        org.clojure/tools.analyzer.jvm {:mvn/version "1.4.0-beta1"}
        org.clojure/tools.namespace    {:mvn/version "1.5.1"}
        org.clojure/tools.cli          {:mvn/version "1.0.214"}
        org.clojure/tools.deps         {:mvn/version "0.29.1598"}
        org.babashka/sci               {:mvn/version "0.12.51"}
        commons-io/commons-io          {:mvn/version "2.11.0"}
        com.cognitect/transit-clj      {:mvn/version "1.0.333"}
        nrepl/nrepl                    {:mvn/version "1.3.1"}}
 :aliases
 {;; Skeptic's worker runtime dependency declaration. The deps.edn tool path
  ;; resolves this alias via `tools.deps/create-basis {:aliases [:worker]}`
  ;; and hands the resolved classpath roots to the worker spawn as the
  ;; runtime-cp tail of the launch classpath. project.clj's :worker profile
  ;; declares the SAME coordinates for the lein-skeptic plugin path. The 11
  ;; coordinates are the namespaces load-bearing for the worker JVM: clojure,
  ;; clojurescript, tools.analyzer(.jvm), tools.reader, tools.namespace,
  ;; core.cache/memoize, data.priority-map, transit-clj, nrepl.
  ;; :replace-deps (not :extra-deps) so resolution starts FROM the worker
  ;; coordinate list, not Skeptic's host deps + worker deps merged.
  :worker
  {:replace-deps
   {org.clojure/clojure             {:mvn/version "1.12.0"}
    org.clojure/clojurescript       {:mvn/version "1.11.132"}
    org.clojure/tools.analyzer      {:mvn/version "1.2.2"}
    org.clojure/tools.analyzer.jvm  {:mvn/version "1.4.0-beta1"}
    org.clojure/tools.reader        {:mvn/version "1.6.0"}
    org.clojure/tools.namespace     {:mvn/version "1.5.1"}
    org.clojure/core.cache          {:mvn/version "1.2.249"}
    org.clojure/core.memoize        {:mvn/version "1.2.273"}
    org.clojure/data.priority-map   {:mvn/version "1.2.1"}
    com.cognitect/transit-clj       {:mvn/version "1.0.333"}
    nrepl/nrepl                     {:mvn/version "1.3.1"}}}

  ;; Skeptic's HOST runtime dependency declaration. Mirrors the
  ;; skeptic.host.deps/host-deps vector so ad-hoc invocations like
  ;; `clj -A:host` are possible. The deps.edn tool path (`clj -T:skeptic
  ;; check`) is itself already hermetic — its host JVM only has Skeptic's
  ;; own resolved deps. This alias is the explicit per-coord declaration.
  :host
  {:replace-deps
   {org.clojars.nomicflux/skeptic   {:mvn/version "0.9.0-rc10"}
    org.clojure/clojure             {:mvn/version "1.12.0"}
    org.clojure/tools.reader        {:mvn/version "1.6.0"}}}}
 :tools/usage {:ns-default skeptic.tool}}
